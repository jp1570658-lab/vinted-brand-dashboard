# PostgreSQL connection (Supabase in LIVE mode, SQLite path in DEMO mode)
DATABASE_URL="file:./prisma/dev.db"

# Google OAuth (for Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Wise API
WISE_API_KEY=
WISE_PROFILE_ID=

# Vinted scraper (LIVE only) — detects sold items by scraping your own wardrobe
# daily at 06:00, replacing the Gmail sale detector. Read-only, your account only.
#   VINTED_DOMAIN  : the TLD you log in on, e.g. www.vinted.co.uk / www.vinted.fr
#   VINTED_USER_ID : your numeric id (from your profile URL /member/<id>)
#   VINTED_COOKIE  : full Cookie header from a logged-in browser request
#                    (DevTools → Network → any request → Request Headers → Cookie;
#                     must include access_token_web). Refresh when it expires.
VINTED_DOMAIN=www.vinted.co.uk
VINTED_USER_ID=
VINTED_COOKIE=
# Timezone for the daily 06:00 scrape (IANA name). Hosts run in UTC by default,
# so set this to your zone, e.g. Europe/Amsterdam, to get your local 6 AM.
CRON_TZ=Europe/Amsterdam

# Anthropic Claude API
ANTHROPIC_API_KEY=

# App security
SESSION_SECRET=change-me-to-a-long-random-string
DASHBOARD_PASSWORD=demo1234

# Email alerts (LIVE only — Gmail address + 16-char app password)
ALERT_EMAIL_USER=
ALERT_EMAIL_PASS=
ALERT_EMAIL_TO=

# Server
PORT=3001
NODE_ENV=development

# Build mode: DEMO or LIVE
APP_MODE=DEMO
