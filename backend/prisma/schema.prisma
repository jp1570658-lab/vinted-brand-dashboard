// Vinted Brand Dashboard — Prisma schema
// DEMO mode: SQLite (provider below). LIVE mode: change provider to "postgresql"
// and point DATABASE_URL at Supabase (see DEPLOYMENT.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  SOURCED
  IN_TRANSIT
  IN_STOCK
  SOLD
}

model Item {
  id               String             @id @default(uuid())
  brand            String
  model            String
  grade            String?
  color            String?
  photoUrl         String?
  status           ItemStatus         @default(SOURCED)
  sourcedAt        DateTime           @default(now())
  transitAt        DateTime?
  stockAt          DateTime?
  soldAt           DateTime?
  purchasePrice    Float
  purchaseCurrency String             @default("EUR")
  purchasePriceEur Float?
  shippingCost     Float?
  customsFees      Float?
  listedPrice      Float?
  salePrice        Float?
  netProfit        Float?
  vintedLikes      Int? // latest ❤ favourite count scraped from the Vinted listing
  notes            String?
  vintedOrderId    String?
  saleSource       String? // "AUTO_GMAIL" | "AUTO_VINTED" | "MANUAL"
  runnerId         String?
  runner           Runner?            @relation(fields: [runnerId], references: [id])
  wiseTransactions WiseTransaction[]
  txSplits         TransactionSplit[]
  deletedAt        DateTime? // soft delete
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@index([sourcedAt])
  @@index([soldAt])
  @@index([deletedAt])
}

model Runner {
  id        String   @id @default(uuid())
  name      String
  location  String
  contact   String?
  items     Item[]
  createdAt DateTime @default(now())
}

model WiseTransaction {
  id          String             @id @default(uuid())
  wiseId      String             @unique
  date        DateTime
  amount      Float
  currency    String
  amountEur   Float?
  description String
  category    String?
  itemId      String?
  item        Item?              @relation(fields: [itemId], references: [id])
  splits      TransactionSplit[]
  createdAt   DateTime           @default(now())

  @@index([date])
  @@index([category])
}

// Splits one expense across several items: each row allocates an EUR portion of
// the parent transaction to one item's cost. Lets a single "Bags purchase" feed
// real per-item cost (and net profit). Replaces the single `itemId` link when used.
model TransactionSplit {
  id            String          @id @default(uuid())
  transactionId String
  transaction   WiseTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item            @relation(fields: [itemId], references: [id])
  amount        Float // EUR portion allocated to this item
  applyAs       String          @default("PURCHASE") // "PURCHASE" | "SHIPPING"
  createdAt     DateTime        @default(now())

  @@index([transactionId])
  @@index([itemId])
}

model GmailSync {
  id         String   @id @default(uuid())
  lastSyncAt DateTime
  emailCount Int
  salesFound Int
}

// One row per run of the daily Vinted wardrobe scrape (replaces Gmail polling).
model VintedSync {
  id           String   @id @default(uuid())
  lastSyncAt   DateTime
  listingsSeen Int
  salesFound   Int
}

// Snapshot of wardrobe listings, used for diff-based sold detection: a listing
// that was active on a previous run but is gone today is treated as sold.
model VintedListing {
  id             String   @id @default(uuid())
  vintedItemId   String   @unique
  title          String
  price          Float?
  favouriteCount Int? // latest ❤ likes on the listing (demand signal)
  active         Boolean  @default(true)
  soldDetected   Boolean  @default(false)
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime
  createdAt      DateTime @default(now())

  @@index([active])
}

// One row per listing per scrape — the engagement time-series. Lets the AI see how
// demand (likes) and price evolved over a listing's life and where it stood when it
// sold, instead of only a single point-in-time number.
model VintedListingSnapshot {
  id           String   @id @default(uuid())
  vintedItemId String
  likes        Int?
  price        Float?
  active       Boolean
  takenAt      DateTime @default(now())

  @@index([vintedItemId])
  @@index([takenAt])
}

// Persists the live Vinted web session in LIVE mode. Vinted's refresh tokens are
// single-use and rotate on every refresh, so the latest cookie jar (rotating
// refresh_token_web + _vinted_fr_session + datadome) must survive across runs and
// restarts. `seed` records the VINTED_COOKIE env value this row was bootstrapped
// from, so updating the env (after a re-login) transparently re-seeds the jar.
model VintedAuth {
  id        String   @id @default("singleton")
  cookie    String // live cookie jar, updated after every token refresh
  seed      String // the VINTED_COOKIE env value this jar was initialized from
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Persists the Google OAuth refresh token in LIVE mode (Step 6).
model GoogleToken {
  id           String    @id @default(uuid())
  refreshToken String
  accessToken  String?
  expiry       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
