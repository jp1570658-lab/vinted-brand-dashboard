# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto eol=lf

# Source & config — always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.prisma text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env.example text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never touch
*.mp4   binary
*.m4a   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.pdf   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.ico   binary
*.db    binary
